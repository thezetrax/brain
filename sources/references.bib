@comment {
    Add each book as an book entry.
    Required fields are usually: title, author, year.
    Authors are separated with "and" and written as: Last, First.
    Example for 3 authors:
    author = {Grant, Keith J. and Drasner, Sarah and Powell, Kevin}

    NOTE!
    ------
    Do not include URL and year in the same entry.
}

@book{grant2024,
    title = {CSS in Depth},
    author = {Grant, Keith J.},
    year = {2024},
}

@online{webdev-viewport-units,
    author = {wed.dev},
    title = {The large, small, and dynamic viewport units},
    URL = {https://web.dev/blog/viewport-units},
}
